// prisma/schema.prisma
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User model
model tbl_pengguna {
  id              String    @id @default(uuid())
  username        String    @unique
  password_hash   String
  nama_lengkap    String
  role            Role       @default(PETUGAS_VERIFIKATOR) // Default role as specified in requirements for PETUGAS_VERIFIKATOR below
  status_akun     StatusAkun @default(AKTIF)
  login_attempts  Int        @default(0)
  locked_until    DateTime?
  created_at      DateTime   @default(now())

  audit_logs                  tbl_audit_log[]
  aid_verifications           aid_verification[]
  aid_distributions           aid_distribution[]
  aid_application_transitions aid_application_transition[]
}

enum Role {
  ADMINISTRATOR
  KEPALA_BIDANG
  PETUGAS_VERIFIKATOR
}

enum StatusAkun {
  AKTIF
  NONAKTIF
  TERKUNCI
}

// Recipient model
model tbl_penerima {
  id                       String        @id @default(uuid())
  nik                      Bytes         @unique // 16 char NIK
  nama_lengkap             String
  tanggal_lahir            DateTime
  jenis_kelamin            JenisKelamin
  alamat                   String
  nomor_telepon            String
  jumlah_anggota_keluarga  Int
  jenis_pekerjaan          String
  status_kepemilikan_rumah String
  keterangan_ekonomi       String
  status_verifikasi        StatusVerifikasi @default(MENUNGGU)
  created_at               DateTime      @default(now())

  fotos                    tbl_foto[]
  desil_data               tbl_desil[]
  penyaluran               tbl_penyaluran[]
  sanggahan                tbl_sanggahan[]
  aid_applications         aid_application[] @relation("central_record_application")
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusVerifikasi {
  MENUNGGU
  MATCH
  MISMATCH
  DISETUJUI
  DITOLAK
}

// Photo model
model tbl_foto {
  id          String    @id @default(uuid())
  id_penerima String
  url_foto    Bytes
  nama_file   String
  created_at  DateTime  @default(now())

  penerima    tbl_penerima @relation(fields: [id_penerima], references: [id])
}

// Desil model
model tbl_desil {
  id                   String            @id @default(uuid())
  id_penerima          String
  nik                  Bytes
  nilai_desil          Int               @map("nilai_desil") // 1-10
  sumber_data          String
  status_sinkronisasi  StatusSinkronisasi @default(TERTUNDA)
  tanggal_sinkronisasi DateTime

  penerima             tbl_penerima      @relation(fields: [id_penerima], references: [id])
}

enum StatusSinkronisasi {
  MATCH
  MISMATCH
  TERTUNDA
}

// Distribution model
model tbl_penyaluran {
  id                   String             @id @default(uuid())
  id_penerima          String
  jenis_bantuan        JenisBantuan
  metode_penyaluran    MetodePenyaluran
  nominal_bantuan      Decimal
  status_penyaluran    StatusPenyaluran   @default(MENUNGGU)
  catatan              String?
  created_at           DateTime           @default(now())
  tanggal_penyaluran   DateTime

  penerima             tbl_penerima       @relation(fields: [id_penerima], references: [id])
}

enum JenisBantuan {
  PKH
  BPNT
  BLT
}

enum MetodePenyaluran {
  BANK
  EWALLET
  FISIK
}

enum StatusPenyaluran {
  MENUNGGU
  DIPROSES
  BERHASIL
  GAGAL
}

// Audit Log model
model tbl_audit_log {
  id        String    @id @default(uuid())
  id_pengguna String
  aksi      String
  deskripsi String
  note      String?
  waktu_aksi DateTime  @default(now())

  pengguna  tbl_pengguna @relation(fields: [id_pengguna], references: [id])
}

// Complaint model
model tbl_sanggahan {
  id               String          @id @default(uuid())
  id_penerima      String
  nama_pengaju     String
  isi_sanggahan    String
  tanggal_sanggahan DateTime       @default(now())
  status_sanggahan StatusSanggahan @default(PENDING)

  penerima         tbl_penerima    @relation(fields: [id_penerima], references: [id])
}

enum StatusSanggahan {
  PENDING
  DITINJAU
  SELESAI
}

// Warga registry model for public eligibility checking
model tbl_warga {
  id                  String      @id @default(uuid())
  nik                 Bytes       @unique
  nama_lengkap        String
  alamat              String
  wilayah             String
  status_dtks         StatusDtks  @default(BELUM_TERDAFTAR)
  nilai_kesejahteraan Int
  is_dalam_jangkauan  Boolean     @default(true)
  catatan             String?
  created_at          DateTime    @default(now())
}

enum StatusDtks {
  TERDAFTAR
  BELUM_TERDAFTAR
  LUAR_JANGKAUAN
  DATA_TIDAK_ADA
}

model aid_application {
  id                           String                   @id @default(uuid())
  application_number           String                   @unique
  nik                          Bytes
  nama_lengkap                 String
  tanggal_lahir                DateTime
  jenis_kelamin                JenisKelamin
  alamat                       String
  nomor_telepon                String
  jumlah_anggota_keluarga      Int
  jenis_pekerjaan              String
  status_kepemilikan_rumah     String
  keterangan_ekonomi           String
  status                       AidApplicationStatus     @default(SUBMITTED)
  assigned_program             AidProgram?
  assigned_distribution_method AidDistributionMethod?
  nominal_bantuan              Decimal?
  validation_summary           String?
  admin_note                   String?
  rejection_reason             String?
  field_verification_required  Boolean                  @default(false)
  submitted_at                 DateTime                 @default(now())
  approved_at                  DateTime?
  distributed_at               DateTime?
  updated_at                   DateTime                 @updatedAt
  id_penerima_pusat            String?                  @unique

  central_record     tbl_penerima?                 @relation("central_record_application", fields: [id_penerima_pusat], references: [id])
  documents          aid_application_document[]
  validation_results aid_validation_result[]
  verifications      aid_verification[]
  distributions      aid_distribution[]
  transitions        aid_application_transition[]

  @@index([status])
  @@index([submitted_at])
}

model aid_application_document {
  id             String          @id @default(uuid())
  application_id String
  document_type  AidDocumentType
  file_url       Bytes
  file_name      String
  uploaded_at    DateTime        @default(now())

  application aid_application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@index([application_id])
}

model aid_validation_result {
  id             String              @id @default(uuid())
  application_id String
  source         AidValidationSource
  result         AidValidationResult
  message        String
  detail_json    String?
  created_at     DateTime            @default(now())

  application aid_application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@index([application_id, source])
}

model aid_verification {
  id                        String           @id @default(uuid())
  application_id            String
  verifier_id               String
  decision                  AidAdminDecision
  notes                     String
  field_verification_needed Boolean          @default(false)
  verified_at               DateTime         @default(now())

  application aid_application @relation(fields: [application_id], references: [id], onDelete: Cascade)
  verifier    tbl_pengguna    @relation(fields: [verifier_id], references: [id])

  @@index([application_id])
  @@index([verifier_id])
}

model aid_distribution {
  id                 String                         @id @default(uuid())
  application_id     String
  executed_by_id     String?
  program            AidProgram
  method             AidDistributionMethod
  status             AidDistributionExecutionStatus @default(QUEUED)
  nominal_bantuan    Decimal
  external_reference String?
  notes              String?
  created_at         DateTime                       @default(now())
  executed_at        DateTime?

  application aid_application @relation(fields: [application_id], references: [id], onDelete: Cascade)
  executed_by tbl_pengguna?  @relation(fields: [executed_by_id], references: [id])

  @@index([application_id])
  @@index([status])
}

model aid_application_transition {
  id             String               @id @default(uuid())
  application_id String
  actor_id       String?
  actor_type     AidActorType
  from_status    AidApplicationStatus?
  to_status      AidApplicationStatus
  notes          String?
  metadata_json  String?
  created_at     DateTime             @default(now())

  application aid_application @relation(fields: [application_id], references: [id], onDelete: Cascade)
  actor       tbl_pengguna?   @relation(fields: [actor_id], references: [id])

  @@index([application_id, created_at])
}

enum AidApplicationStatus {
  SUBMITTED
  VALIDATING
  REJECTED_INVALID
  PENDING_ADMIN_VERIFICATION
  REJECTED_ADMIN
  APPROVED
  CENTRALIZED
  PROGRAM_ASSIGNED
  DISTRIBUTION_IN_PROGRESS
  DISTRIBUTED
}

enum AidDocumentType {
  KTP
  KK
  SURAT_KETERANGAN
  FOTO_RUMAH
  FOTO_PENDUKUNG
  LAINNYA
}

enum AidValidationSource {
  KEMENSOS_DECILE
  ADMINISTRATIVE_RECORD
}

enum AidValidationResult {
  PASSED
  FAILED
  ERROR
}

enum AidAdminDecision {
  APPROVED
  REJECTED
}

enum AidProgram {
  PKH
  BPNT
  BLT
}

enum AidDistributionMethod {
  BANK_TRANSFER
  E_WALLET
  PHYSICAL_DISTRIBUTION
}

enum AidDistributionExecutionStatus {
  QUEUED
  PROCESSING
  SUCCESS
  FAILED
}

enum AidActorType {
  CITIZEN
  SYSTEM
  ADMIN
  SUPERVISOR
}
